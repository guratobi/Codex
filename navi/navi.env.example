# 나비 설정 — 이 파일을 navi.env 로 복사해서 채운다. (navi.env 는 깃에 안 올라감)
#   cp navi.env.example navi.env

# [필수] 텔레그램 봇 토큰 (날씨 봇과 같은 걸 재사용해도 됨)
TELEGRAM_TOKEN=

# [선택] 비워두면 봇에게 '처음 말 건 사람'을 주인으로 자동 등록한다
TELEGRAM_CHAT_ID=

# brain 폴더 (별도 비공개 깃 레포 권장 — 장부가 거기 쌓인다)
NAVI_BRAIN_DIR=/home/YOUR_USER/navi-brain

# 먼저 알려줄 시각 (HH:MM, 24시간, 앞자리 0 포함). 회사=평일만 / 집=매일
NAVI_PUSH_WORK=08:50
NAVI_PUSH_HOME=19:00

# brain 이 깃 레포일 때 변경분 자동 커밋/푸시 (끄려면 off)
NAVI_GIT=on

# 채팅 자동 청소: 이 시간(시간)보다 오래된 나비 채팅 메시지를 지운다.
# 할 일은 brain 에 안전히 남으니 채팅창은 비워도 OK. 0=끔, 최대 47(텔레그램 제한).
NAVI_CHAT_TTL_HOURS=12

# [옵션] GPS 도착 푸시용 웹훅. 쓸 거면 둘 다 채운다.
# NAVI_WEBHOOK_PORT=8787
# NAVI_WEBHOOK_SECRET=아무거나-길고-비밀스러운-문자열

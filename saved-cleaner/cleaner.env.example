# 저장한 메시지 청소기 설정 — cleaner.env 로 복사해 채운다. (깃에 안 올라감)
# API_ID / API_HASH 발급: https://my.telegram.org → "API development tools"
TG_API_ID=
TG_API_HASH=

# 첫 로그인 편의(선택). 국가코드 포함: +82109...
TG_PHONE=

# 며칠 지난 걸 지울까. 컨베이어니까 짧게 (1~7 추천)
KEEP_DAYS=3

# true=사진/문서만 삭제(텍스트·링크 북마크 보존) / false=오래된 거 전부
ONLY_FILES=true

# 첫 실행은 true 로 — '몇 개 지울지'만 확인하고, 안전하면 false 로 바꾼다
DRY_RUN=true
